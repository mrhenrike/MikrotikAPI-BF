# MikrotikAPI-BF — Environment Variables Template
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and must NEVER be committed to the repo.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your real values
#   python mikrotikapi-bf.py --help

# ── API Keys ──────────────────────────────────────────────────────────────────

# Shodan API key (for --fingerprint Shodan enrichment and recon)
# Get at: https://account.shodan.io/
SHODAN_KEY=

# NVD (National Vulnerability Database) API key
# Get at: https://nvd.nist.gov/developers/request-an-api-key
NVD_KEY=

# ── CERT/CC VINCE (vulnerability coordination) ───────────────────────────────

# VINCE API token for coordinated disclosure automation
# Get at: https://kb.cert.org/vince/
VINCE_TOKEN=

# ── Lab / Test Infrastructure ────────────────────────────────────────────────

# Default lab target for quick tests (NOT production)
LAB_TARGET=

# Lab credentials (authorized test environment only)
LAB_USER=admin
LAB_PASS=

# ── Optional: BugHunt (BR bug bounty platform) ───────────────────────────────

# JWT obtained after manual login at https://admin.bughunt.com.br
# Expires after ~24h — must be refreshed manually (protected by reCAPTCHA)
BUGHUNT_TOKEN=

# ── Optional: proxy for stealth mode ─────────────────────────────────────────

# Example: socks5://127.0.0.1:9050 (Tor)
PROXY_URL=
