# MikrotikAPI-BF — Environment Variables Template
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and must NEVER be committed to the repo.
#
# Usage:
#   cp .env.example .env   (Linux/macOS)
#   Copy-Item .env.example .env   (Windows PowerShell)
#   # Edit .env and add your real API keys

# ── Shodan API key ────────────────────────────────────────────────────────────
# Used by --fingerprint to enrich device info with Shodan internet scan data.
# Get at: https://account.shodan.io/
SHODAN_KEY=

# ── NVD (National Vulnerability Database) API key ────────────────────────────
# Used by --scan-cve to fetch CVE details and CVSS scores from NVD REST API v2.
# Get at: https://nvd.nist.gov/developers/request-an-api-key
NVD_KEY=

# ── Optional: proxy for stealth mode ─────────────────────────────────────────
# Example: socks5://127.0.0.1:9050 (Tor)
# Used by --proxy flag if set here.
PROXY_URL=
